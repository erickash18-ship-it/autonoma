# === Autonoma Configuration ===
# Copy this file to .env and fill in your values
# Or run: npm run setup

# --- Required ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_CHAT_ID=your_telegram_chat_id_here

# --- Bot Identity ---
BOT_NAME=Autonoma
OWNER_NAME=Your Name

# --- Timezone ---
TIMEZONE=America/New_York

# --- Features (true/false) ---
ENABLE_SCHEDULER=true
ENABLE_VOICE=false
ENABLE_TTS=false
ENABLE_CALENDAR=false
ENABLE_DASHBOARD=true
ENABLE_BRIEFING=false
ENABLE_CHECKIN=false

# --- Memory ---
# full = FTS5 search + semantic/episodic + decay
# simple = conversation history only
# none = stateless
MEMORY_MODE=full

# --- Agent Limits ---
MAX_CONCURRENT_AGENTS=4

# --- Dashboard ---
GATEWAY_TOKEN=change-me-to-something-random
GATEWAY_PORT=39217

# --- Google Calendar (optional) ---
# Create OAuth2 credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Voice (optional) ---
# Get Groq API key at https://groq.com
GROQ_API_KEY=
# Get ElevenLabs API key at https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Logging ---
LOG_LEVEL=info
