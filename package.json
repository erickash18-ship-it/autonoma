{
  "name": "autonoma",
  "version": "0.1.0",
  "description": "Personal AI assistant Telegram bot framework powered by Claude Agent SDK",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "tsx scripts/setup.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "logs": "tail -f /tmp/autonoma.log"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "better-sqlite3": "^11.0.0",
    "cron-parser": "^5.0.0",
    "googleapis": "^144.0.0",
    "grammy": "^1.30.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
